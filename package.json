{
  "name": "atlas",
  "private": true,
  "version": "0.1.0",
  "description": "ATLAS — Enterprise Operating System of AGHA RM INFRA",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "multer": ">=2.2.0",
      "undici": ">=7.28.0"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @atlas/core dev",
    "start": "pnpm --filter @atlas/core start",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @atlas/core db:generate",
    "db:migrate": "pnpm --filter @atlas/core db:migrate"
  }
}
