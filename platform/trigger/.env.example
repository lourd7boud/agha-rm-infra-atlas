# Trigger.dev v4 self-hosted — secrets template.
# Copy to .env on the target VPS (git-ignored) and REGENERATE every secret:
#   openssl rand -hex 16
# The defaults below are placeholders — they MUST NOT reach production.

# ── Trigger secrets ──────────────────────────────────────────────────────────
SESSION_SECRET=REGENERATE_openssl_rand_hex_16
MAGIC_LINK_SECRET=REGENERATE_openssl_rand_hex_16
ENCRYPTION_KEY=REGENERATE_openssl_rand_hex_16
MANAGED_WORKER_SECRET=REGENERATE_openssl_rand_hex_16

# Set AFTER the webapp is running: read from its logs on first boot
# (the token is shown ONCE only, then required for the worker to register).
TRIGGER_WORKER_TOKEN=

# ── Postgres (Trigger.dev's OWN DB — not ATLAS's) ────────────────────────────
POSTGRES_PASSWORD=REGENERATE_openssl_rand_hex_16

# ── ClickHouse (analytics store) ─────────────────────────────────────────────
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=REGENERATE_openssl_rand_hex_16

# ── MinIO (packet cache for task builds) ─────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=REGENERATE_openssl_rand_hex_16

# ── Docker registry (task images live here) ──────────────────────────────────
DOCKER_REGISTRY_USERNAME=atlas-tasks
DOCKER_REGISTRY_PASSWORD=REGENERATE_openssl_rand_hex_16

# ── App origin (public URL — set to your Trigger.dev subdomain) ──────────────
# For a dedicated VPS behind nginx + certbot, pattern is:
#   trigger.marocinfra.com  →  127.0.0.1:8030
APP_ORIGIN=https://trigger.marocinfra.com

# ── Image tag (pin in production for reproducibility) ────────────────────────
TRIGGER_IMAGE_TAG=v4-beta

# ── Node heap size (webapp) — sized to VPS RAM ───────────────────────────────
# 8 GB VPS → 6144    (leave 25% headroom)
# 16 GB VPS → 12800
NODE_MAX_OLD_SPACE_SIZE=6144
