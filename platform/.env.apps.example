# ATLAS apps environment template (Core API + staff portal).
# Copy to .env.apps and replace EVERY value. .env.apps is git-ignored.
# Generate strong values: openssl rand -base64 32

# --- Core API ---
# atlas database user — created by initdb/01-databases.sql on the platform stack
DATABASE_URL=postgres://atlas:CHANGE_ME@postgres:5432/atlas
REDIS_URL=redis://redis:6379
OIDC_ISSUER=https://auth.example.ma/realms/atlas

# --- Vault object storage (MinIO on the shared network) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
VAULT_BUCKET=atlas-vault

# --- LLM gateway (Brain module; rotate any key that ever transited chat) ---
LLM_API_BASE=https://api.qcode.cc
LLM_API_KEY=CHANGE_ME
LLM_MODEL_T1=claude-haiku-4-5-20251001
LLM_MODEL_T2=claude-sonnet-4-6
LLM_MODEL_T3=claude-fable-5

# --- Portal watchers (flip to live once real snapshots are sanctioned) ---
# The consultation rows are server-rendered on the advanced-search page
# (Atexo MPE), NOT the /pmmp/ landing page. The parser handles this layout.
# WATCH_SOURCE=live
# WATCH_PMMP_URL=https://www.marchespublics.gov.ma/index.php?page=entreprise.EntrepriseAdvancedSearch&AllCons&EnCours
# INTEL_SOURCE=live
# INTEL_PMMP_URL=https://www.marchespublics.gov.ma/index.php?page=entreprise.EntrepriseAdvancedSearch&AllCons&Resultat

# --- Staff portal (Next.js + next-auth v5) ---
AUTH_SECRET=CHANGE_ME
AUTH_KEYCLOAK_ID=atlas-portal
AUTH_KEYCLOAK_SECRET=CHANGE_ME
AUTH_KEYCLOAK_ISSUER=https://auth.example.ma/realms/atlas
AUTH_URL=https://atlas.example.ma
AUTH_TRUST_HOST=true
ATLAS_API_URL=http://core:3000/api
