# ATLAS apps environment template (Core API + staff portal).
# Copy to .env.apps and replace EVERY value. .env.apps is git-ignored.
# Generate strong values: openssl rand -base64 32

# --- Core API ---
# atlas database user — created by initdb/01-databases.sql on the platform stack
DATABASE_URL=postgres://atlas:CHANGE_ME@postgres:5432/atlas
REDIS_URL=redis://redis:6379
OIDC_ISSUER=https://auth.example.ma/realms/atlas

# --- Vault object storage (MinIO on the shared network) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
VAULT_BUCKET=atlas-vault

# --- LLM gateway (Brain module; rotate any key that ever transited chat) ---
# The gateway serves the Anthropic Messages protocol under /api — the SDK
# appends /v1/messages. Without /api the gateway 404s ("Route not found").
LLM_API_BASE=https://api.qcode.cc/api
LLM_API_KEY=CHANGE_ME
LLM_MODEL_T1=claude-haiku-4-5-20251001
LLM_MODEL_T2=claude-sonnet-4-6
LLM_MODEL_T3=claude-fable-5

# --- OpenRouter (OpenAI-protocol) — takes precedence over LLM_API_* when set ---
# A single fast model fills every tier (tender enrichment + brain agents).
# SECRET: rotate any key that ever transits chat. Set in the deploy store only.
# OPENROUTER_API_KEY=CHANGE_ME
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# --- Per-tender chat (Chat IA) — dedicated STRONG model ---
# The per-tender "Chat IA" runs on a TOP model (Opus), not the fast extraction
# model. Credentials fall back CHAT_* → LLM_* → OPENROUTER_*, so with LLM_API_KEY
# + LLM_API_BASE (qcode /api) already set above, ONLY CHAT_LLM_MODEL is required —
# the chat reuses the same key/base and routes claude-* over the Anthropic path.
CHAT_LLM_MODEL=claude-opus-4-8
# Optional: bill the chat to a SEPARATE key/base instead of reusing LLM_API_*.
# SECRET: set in the deploy store only, never commit.
# CHAT_LLM_API_KEY=CHANGE_ME
# CHAT_LLM_API_BASE=https://api.qcode.cc/api

# --- Portal authenticated session (marchespublics.gov.ma; no CAPTCHA/2FA) ---
# Entreprise portal account (read-only after the login POST). Set these in the
# deploy secret store only — never commit real values.
PORTAL_AUTH_LOGIN=
PORTAL_AUTH_PASSWORD=

# --- Portal watchers (flip to live once real snapshots are sanctioned) ---
# The consultation rows are server-rendered on the advanced-search page
# (Atexo MPE), NOT the /pmmp/ landing page. The parser handles this layout.
# WATCH_SOURCE=live
# WATCH_PMMP_URL=https://www.marchespublics.gov.ma/index.php?page=entreprise.EntrepriseAdvancedSearch&AllCons&EnCours
# INTEL_SOURCE=live
# INTEL_PMMP_URL=https://www.marchespublics.gov.ma/index.php?page=entreprise.EntrepriseAdvancedSearch&AllCons&Resultat
#
# Deep crawl (pagination): the portal returns ~10 rows on its default first
# page (verified: ~390 pages of open consultations exist). The Sentinel walks
# pages until the parsed result set repeats, a page yields nothing, a fetch
# fails, or WATCH_MAX_PAGES is hit. Two mechanisms:
#
# (A) marchespublics.gov.ma (Atexo MPE) — VERIFIED: the pager is a stateful
#     PRADO POST (PRADO_PAGESTATE + PRADO_POSTBACK_TARGET), NOT a GET param.
#     Enable the deep crawl with:
# WATCH_PORTAL_MODE=prado
# WATCH_MAX_PAGES=50          # raise toward ~390 to cover the full backlog
# WATCH_PAGE_DELAY_MS=1200    # be extra polite on the government portal
#
# (B) Generic GET-paginated portals — set WATCH_PAGE_PARAM (off by default).
# WATCH_PAGE_PARAM=pageActuelle   # 1-based page index param (confirm live name)
# WATCH_FIRST_PAGE_INDEX=1    # index the portal uses for page 1 (default 1)
# WATCH_PAGE_SIZE_PARAM=...   # optional results-per-page param + value
# WATCH_PAGE_SIZE=50

# --- Bons de commande (PMMP public mirror) ---
# The dedicated worker checks for new purchase-order notices automatically.
# Default cadence is every 15 minutes; tune only if the portal allows it.
# BDC_CRON=*/15 * * * *
# BDC_SWEEP_PAGES=5
# BDC_SWEEP_DETAILS=30
# BDC_SWEEP_RESULTATS=3

# --- Staff portal (Next.js + next-auth v5) ---
AUTH_SECRET=CHANGE_ME
AUTH_KEYCLOAK_ID=atlas-web
# Leave blank for the public client from platform/keycloak/atlas-realm.json.
# Set a real value only if you reconfigure the realm client as confidential.
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=https://auth.example.ma/realms/atlas
AUTH_URL=https://atlas.example.ma
AUTH_TRUST_HOST=true
ATLAS_API_URL=http://core:3000/api
