    },
    {
      "username": "chantier",
      "email": "chantier@dev.local",
      "firstName": "Chef",
      "lastName": "Chantier",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "dev-chantier-password", "temporary": false }
