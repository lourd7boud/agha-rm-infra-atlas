{
  "realm": "atlas",
  "enabled": true,
  "registrationAllowed": false,
  "loginTheme": "keycloak",
  "sslRequired": "external",
  "roles": {
    "realm": [
      { "name": "direction", "description": "Direction Générale — gates G1/G2/G3" },
      { "name": "marches", "description": "Division Marchés" },
      { "name": "travaux", "description": "Direction Travaux" },
      { "name": "finance", "description": "Direction Administrative & Financière" },
      { "name": "terrain", "description": "Field staff (mobile)" },
