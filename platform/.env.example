# ATLAS Platform environment template.
# Copy to .env and replace EVERY value. .env is git-ignored — never commit it.
# Generate strong values: openssl rand -base64 24

# --- Routing / TLS ---
DOMAIN=atlas.example.ma
ACME_EMAIL=admin@example.ma

# --- PostgreSQL ---
POSTGRES_PASSWORD=change-me-strong
KEYCLOAK_DB_PASSWORD=change-me-strong
ODOO_DB_PASSWORD=change-me-strong
METABASE_DB_PASSWORD=change-me-strong

# --- Keycloak bootstrap admin (rotate after realm setup) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong

# --- MinIO ---
MINIO_ROOT_USER=atlas-admin
MINIO_ROOT_PASSWORD=change-me-strong

# --- AI (used by ATLAS Core / agents, not by this compose file yet) ---
ANTHROPIC_API_KEY=sk-ant-replace-me
