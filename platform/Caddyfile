{
	email {$ACME_EMAIL}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

atlas.{$DOMAIN} {
	import security_headers
	reverse_proxy web:3001
}

api.{$DOMAIN} {
	import security_headers
	# Prometheus scrapes core:3000 over the internal network — the public
	# internet never needs the scrape endpoint (service fingerprinting risk).
	@metrics path /api/metrics /api/metrics/*
	respond @metrics 403
	reverse_proxy core:3000
}

auth.{$DOMAIN} {
	reverse_proxy keycloak:8080
}

erp.{$DOMAIN} {
	reverse_proxy odoo:8069
}

bi.{$DOMAIN} {
	reverse_proxy metabase:3000
}

s3.{$DOMAIN} {
	reverse_proxy minio:9000
}

s3c.{$DOMAIN} {
	# MinIO console — admin surface, only reachable from Tailscale (100.64/10)
	# or private/LAN ranges. Everyone else gets a hard 403.
	@public {
		not remote_ip private_ranges 100.64.0.0/10
	}
	respond @public 403
	reverse_proxy minio:9001
}
