# ATLAS Web environment template — copy to .env.local (git-ignored).

# Auth.js session encryption secret: generate with `openssl rand -base64 32`.
AUTH_SECRET=replace-me

# Keycloak OIDC client for the portal (Authorization Code + PKCE).
# The dev realm import ships `atlas-web` as a public client, so the secret stays blank
# unless you explicitly switch the realm client to confidential.
AUTH_KEYCLOAK_ID=atlas-web
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=http://localhost:8081/realms/atlas

# Public URL of this app (must match Keycloak client redirect URI).
AUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# ATLAS Core API base.
ATLAS_API_URL=http://localhost:3000/api
