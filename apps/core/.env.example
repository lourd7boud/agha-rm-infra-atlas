# ATLAS Core environment template — copy to .env (git-ignored).
# Dev values match platform/docker-compose.dev.yml.

# Without DATABASE_URL the API boots with an in-memory vault repository
# (useful for UI work); with it, data persists in PostgreSQL.
DATABASE_URL=postgres://atlas:atlas-dev@localhost:5433/atlas

PORT=3000

# Keycloak realm issuer. Unset = AUTH DISABLED (dev only, never production).
# Dev realm is auto-imported from platform/keycloak/atlas-realm.json.
OIDC_ISSUER=http://localhost:8081/realms/atlas

# BullMQ queue backend (dev compose Redis).
REDIS_URL=redis://127.0.0.1:6380

# Object storage (dev compose MinIO; any S3-compatible endpoint in prod).
# Unset = vault files use non-persistent in-memory storage.
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
VAULT_BUCKET=atlas-vault

# Sentinel watcher source: fixture (default) or live.
# Live mode needs the PMMP search-results URL once captured/configured:
# WATCH_SOURCE=live
# WATCH_PMMP_URL=https://www.marchespublics.gov.ma/...
# Optional schedule (cron), e.g. 3x/day at 07:00/12:00/17:00:
# WATCH_CRON=0 7,12,17 * * *

# ── LLM (brain / vision-OCR / enrichment) ────────────────────────────────────
# SECRET: LLM_API_KEY is a credential — NEVER commit a real value, NEVER paste a
# live key into a tracked file. Keep the real key only in .env (git-ignored) or a
# secrets manager, and rotate immediately if it is ever exposed. Unset = the LLM
# features (brain endpoints, PV/result vision crawlers, enrichment) stay disabled.
# LLM_API_BASE=https://api.example-llm-gateway.tld
# LLM_API_KEY=<replace-me-do-not-commit>
# LLM_MODEL_T1=<tier-1-fast-model>
# LLM_MODEL_T2=<tier-2-balanced-model>
# LLM_MODEL_T3=<tier-3-deep-model>
#
# OpenRouter (OpenAI-protocol) takes precedence over LLM_API_* when set — a
# single fast model serves every tier (tender enrichment + brain agents).
# SECRET: same rules as LLM_API_KEY above.
# OPENROUTER_API_KEY=<replace-me-do-not-commit>
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# Optional stronger models for the standard/strategic tiers:
# OPENROUTER_MODEL_T2=google/gemini-2.5-flash
# OPENROUTER_MODEL_T3=google/gemini-2.5-flash

# ── Expert agent (AGHA-RM-INFRA) — dedicated TOP-TIER brain ───────────────────
# The two surfaces we depend on — BPU pricing (bordereau des prix) and the
# written Go/No-Go avis — run on the STRONGEST model, NOT the economical
# extraction model. The provider is inferred from the MODEL FAMILY, so a Claude
# model always uses the Anthropic Messages path (LLM_API_KEY + LLM_API_BASE) even
# when LLM_PROVIDER=google — set those for Claude models. Unset EXPERT_LLM_MODEL =
# the expert falls back to the fast extraction model. Overridable via
# EXPERT_LLM_PROVIDER (anthropic|google|openrouter) / EXPERT_LLM_API_KEY /
# EXPERT_LLM_API_BASE when the expert must use a different account or gateway.
#   Claude family (needs LLM_API_KEY + LLM_API_BASE, e.g. qcode ...:cc/api):
# EXPERT_LLM_MODEL=claude-opus-4-8
# EXPERT_LLM_MODEL=claude-fable-5
#   Gemini family (uses OPENROUTER_API_KEY + the /gemini path):
# EXPERT_LLM_MODEL=gemini-2.5-pro

# ── Per-tender chat (Chat IA) — dedicated STRONG model ───────────────────────
# The per-tender "Chat IA" (TenderChatService) is the surface users judge the
# "agent" by, so it runs on a TOP model (Opus), NOT the fast/cheap extraction
# model. Provider is inferred from the MODEL FAMILY (a Claude model uses the
# Anthropic Messages path even under LLM_PROVIDER=google). Credentials fall back
# CHAT_* → LLM_* → OPENROUTER_*, so if LLM_API_KEY + LLM_API_BASE (qcode) are
# already set for the expert, ONLY CHAT_LLM_MODEL is needed. Unset CHAT_LLM_MODEL
# = the chat falls back to the default extraction client (fast Gemini/Haiku).
# SECRET: CHAT_LLM_API_KEY is a credential — same rules as LLM_API_KEY above.
# CHAT_LLM_MODEL=claude-opus-4-8
# CHAT_LLM_API_KEY=<replace-me-do-not-commit>
# CHAT_LLM_API_BASE=https://api.qcode.cc
# CHAT_LLM_PROVIDER=anthropic   # optional override (anthropic|google|openrouter)

# ── Portal connector (authenticated marchespublics.gov.ma account) ───────────
# SECRET: PORTAL_AUTH_PASSWORD is a credential — same rules as LLM_API_KEY above.
# Unset login/password = the two READ-ONLY harvests ("Mes réponses", "Mes
# cautions") are disabled; the read-only outcomes report still serves stored data.
# PORTAL_AUTH_LOGIN=<portal-username>
# PORTAL_AUTH_PASSWORD=<replace-me-do-not-commit>
# Our raison sociale for the win/lose attribution match (default: AGHID CONSTRUCTION):
# PORTAL_OUR_COMPANY=AGHID CONSTRUCTION
# Low-frequency harvest schedule (cron), default daily at 07:00:
# PORTAL_CRON=0 7 * * *

# ── Radar proactif (Niveau 4) ────────────────────────────────────────────────
# Le radar score les marchés en cours et pousse un brief quotidien. Tourne
# uniquement dans le worker container (WATCH_WORKER_ENABLED=true).
# Scan de scoring — cron horaire par défaut:
# RADAR_CRON=0 * * * *
# Brief top-opportunités — cron quotidien 07:00 par défaut:
# RADAR_DIGEST_CRON=0 7 * * *
# Nb max de marchés scorés par passe (les plus récents d'abord):
# RADAR_SCAN_LIMIT=2000
# Taille du top dans le brief + score minimal retenu:
# RADAR_TOP_N=5
# RADAR_MIN_SCORE=60
# Destinataires du brief (CSV); retombe sur DIGEST_RECIPIENTS puis console:
# RADAR_RECIPIENTS=direction@exemple.ma
