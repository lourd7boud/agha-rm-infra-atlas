# ATLAS Core environment template — copy to .env (git-ignored).
# Dev values match platform/docker-compose.dev.yml.

# Without DATABASE_URL the API boots with an in-memory vault repository
# (useful for UI work); with it, data persists in PostgreSQL.
DATABASE_URL=postgres://atlas:atlas-dev@localhost:5433/atlas

PORT=3000

# Keycloak realm issuer. Unset = AUTH DISABLED (dev only, never production).
# Dev realm is auto-imported from platform/keycloak/atlas-realm.json.
OIDC_ISSUER=http://localhost:8081/realms/atlas

# BullMQ queue backend (dev compose Redis).
REDIS_URL=redis://127.0.0.1:6380

# Object storage (dev compose MinIO; any S3-compatible endpoint in prod).
# Unset = vault files use non-persistent in-memory storage.
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
VAULT_BUCKET=atlas-vault

# Sentinel watcher source: fixture (default) or live.
# Live mode needs the PMMP search-results URL once captured/configured:
# WATCH_SOURCE=live
# WATCH_PMMP_URL=https://www.marchespublics.gov.ma/...
# Optional schedule (cron), e.g. 3x/day at 07:00/12:00/17:00:
# WATCH_CRON=0 7,12,17 * * *
