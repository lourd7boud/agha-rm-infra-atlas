# local distributed-worker secrets + helpers (never commit)
.atlas-worker.env
scripts-local/

# Dependencies & build output
node_modules/
dist/
build/
coverage/
.turbo/
.next/
*.tsbuildinfo

# Test/browser artifacts
.playwright-mcp/
atlas-web-*.png
test-results/
playwright-report/

# Recon/debug artifacts — screenshots and captured API dumps never belong in git
/*.png
datao-*.json

# Environment & secrets — only templates are committed
.env
.env.*
!.env.example
!.env.apps.example

# Database backups (volume-mounted in the backup sidecar)
platform/backups/

# Local tool state
.claude/
*.log
.DS_Store
Thumbs.db
